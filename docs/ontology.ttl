@prefix : <https://w3id.org/at#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <https://w3id.org/at#> .

<https://w3id.org/at#> rdf:type owl:Ontology ;
                        <http://purl.org/dc/terms/contributor> :André_Borrmann ,
                                                               :Ekaterina_Petrova ,
                                                               :Pieter_Pauwels ;
                        <http://purl.org/dc/terms/creator> <https://orcid.org/0000-0002-9383-7234> ;
                        <http://purl.org/dc/terms/description> "The Archetype Ontology for building engineering domain classifies buildings, building elements, layersets, and materials that can be assigned to existing building stock. As such, the classes offer to assign average values defined by typical building characteristics and serve as reasonable approximations when detailed building-specific data is unavailable."@en ;
                        <http://purl.org/dc/terms/title> "Building Archetype Ontology"@en ;
                        <http://purl.org/vocab/vann/preferredNamespacePrefix> "at"@en ;
                        <http://purl.org/vocab/vann/preferredNamespaceUri> "https://w3id.org/at#"@en ;
                        rdfs:label "" ;
                        owl:versionInfo "1.0"@en .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/terms/contributor
<http://purl.org/dc/terms/contributor> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/creator
<http://purl.org/dc/terms/creator> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/description
<http://purl.org/dc/terms/description> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/title
<http://purl.org/dc/terms/title> rdf:type owl:AnnotationProperty .


###  http://purl.org/vocab/vann/preferredNamespacePrefix
<http://purl.org/vocab/vann/preferredNamespacePrefix> rdf:type owl:AnnotationProperty .


###  http://purl.org/vocab/vann/preferredNamespaceUri
<http://purl.org/vocab/vann/preferredNamespaceUri> rdf:type owl:AnnotationProperty .


###  http://xmlns.com/foaf/0.1/name
<http://xmlns.com/foaf/0.1/name> rdf:type owl:AnnotationProperty .


###  http://xmlns.com/foaf/0.1/weblog
<http://xmlns.com/foaf/0.1/weblog> rdf:type owl:AnnotationProperty .


#################################################################
#    Datatypes
#################################################################

###  http://www.w3.org/2001/XMLSchema#gYear
xsd:gYear rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  https://w3id.org/at#constructionPeriod
:constructionPeriod rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf owl:topObjectProperty ;
                    rdfs:domain :Building ;
                    rdfs:range :ConstructionPeriod .


###  https://w3id.org/at#hasBuildingArchetype
:hasBuildingArchetype rdf:type owl:ObjectProperty ;
                      rdfs:subPropertyOf owl:topObjectProperty ;
                      rdfs:domain :Building ;
                      rdfs:range :BuildingArchetype .


###  https://w3id.org/at#hasBuildingType
:hasBuildingType rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf owl:topObjectProperty ;
                 rdfs:domain :Building ;
                 rdfs:range :BuildingType .


###  https://w3id.org/at#hasElement
:hasElement rdf:type owl:ObjectProperty ;
            rdfs:domain :Building ;
            rdfs:range :BuildingElement .


###  https://w3id.org/at#hasElementArchetype
:hasElementArchetype rdf:type owl:ObjectProperty ;
                     rdfs:domain :BuildingElement ;
                     rdfs:range :ElementArchetype .


###  https://w3id.org/at#hasLayer
:hasLayer rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf owl:topObjectProperty ;
          rdfs:domain :LayerSet ;
          rdfs:range :Layer .


###  https://w3id.org/at#hasLayerSet
:hasLayerSet rdf:type owl:ObjectProperty ;
             rdfs:domain :BuildingElement ;
             rdfs:range :LayerSet .


###  https://w3id.org/at#hasMaterial
:hasMaterial rdf:type owl:ObjectProperty ;
             rdfs:domain :Layer ;
             rdfs:range :Material .


###  https://w3id.org/at#hasReferenceLayerSet
:hasReferenceLayerSet rdf:type owl:ObjectProperty ;
                      rdfs:subPropertyOf owl:topObjectProperty ;
                      rdfs:domain :LayerSet ;
                      rdfs:range :ReferenceLayerSet .


###  https://w3id.org/at#hasReferenceMaterial
:hasReferenceMaterial rdf:type owl:ObjectProperty ;
                      rdfs:subPropertyOf owl:topObjectProperty ;
                      rdfs:domain :Material ;
                      rdfs:range :ReferenceMaterial .


###  https://w3id.org/at#hasRenovationStatus
:hasRenovationStatus rdf:type owl:ObjectProperty ;
                     rdfs:domain :Building ;
                     rdfs:range :RenovationStatus .


###  https://w3id.org/at#hasResidentialType
:hasResidentialType rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf :hasBuildingType ;
                    rdfs:domain :Residential ;
                    rdfs:range :ApartmentHouse ,
                               :DetachedHouse ,
                               :GalleryHouse ,
                               :MaisonetteHouse ,
                               :SemiDetachedHouse ,
                               :TerraceHouse .


#################################################################
#    Data properties
#################################################################

###  https://w3id.org/at#isConstructedIn
:isConstructedIn rdf:type owl:DatatypeProperty ;
                 rdfs:domain :Building ;
                 rdfs:range xsd:gYear .


#################################################################
#    Classes
#################################################################

###  https://w3id.org/at#ApartmentHouse
:ApartmentHouse rdf:type owl:Class ;
                rdfs:subClassOf :Residential .


###  https://w3id.org/at#Building
:Building rdf:type owl:Class .


###  https://w3id.org/at#BuildingArchetype
:BuildingArchetype rdf:type owl:Class ;
                   owl:equivalentClass [ rdf:type owl:Class ;
                                         owl:oneOf ( :BuildingArchetype01
                                                     :BuildingArchetype02
                                                     :BuildingArchetype03
                                                     :BuildingArchetype04
                                                     :BuildingArchetype05
                                                     :BuildingArchetype06
                                                     :BuildingArchetype07
                                                     :BuildingArchetype08
                                                     :BuildingArchetype09
                                                     :BuildingArchetype10
                                                     :BuildingArchetype11
                                                     :BuildingArchetype12
                                                     :BuildingArchetype13
                                                     :BuildingArchetype14
                                                     :BuildingArchetype15
                                                     :BuildingArchetype16
                                                     :BuildingArchetype17
                                                     :BuildingArchetype18
                                                     :BuildingArchetype19
                                                     :BuildingArchetype20
                                                     :BuildingArchetype21
                                                     :BuildingArchetype22
                                                     :BuildingArchetype23
                                                     :BuildingArchetype24
                                                     :BuildingArchetype25
                                                     :BuildingArchetype26
                                                     :BuildingArchetype27
                                                     :BuildingArchetype28
                                                     :BuildingArchetype29
                                                     :BuildingArchetype30
                                                     :BuildingArchetype31
                                                     :BuildingArchetype32
                                                   )
                                       ] ;
                   rdfs:comment "Building archetypes define and utilise core sets of representative construction structures and systems of a building type, formalised as exemplary buildings. BuildingArchetype os a ontrolled vocabulary (enumeration) containing named individuals (1..n)" .


###  https://w3id.org/at#BuildingElement
:BuildingElement rdf:type owl:Class .


###  https://w3id.org/at#BuildingType
:BuildingType rdf:type owl:Class ;
              rdfs:comment "A building type is a categorical classification of buildings based on the occupation type and other buiding-based characteristics." .


###  https://w3id.org/at#ConstructionPeriod
:ConstructionPeriod rdf:type owl:Class ;
                    owl:equivalentClass [ rdf:type owl:Class ;
                                          owl:oneOf ( <https://w3id.org/at#1946>
                                                      <https://w3id.org/at#1964>
                                                      <https://w3id.org/at#1974>
                                                      <https://w3id.org/at#1991>
                                                      <https://w3id.org/at#2005>
                                                      <https://w3id.org/at#2014>
                                                      <https://w3id.org/at#2018>
                                                    )
                                        ] .


###  https://w3id.org/at#DetachedHouse
:DetachedHouse rdf:type owl:Class ;
               rdfs:subClassOf :Residential .


###  https://w3id.org/at#Door
:Door rdf:type owl:Class ;
      rdfs:subClassOf :BuildingElement .


###  https://w3id.org/at#DoorArchetype
:DoorArchetype rdf:type owl:Class ;
               owl:equivalentClass [ rdf:type owl:Class ;
                                     owl:oneOf ( :DoorArchetype01
                                                 :DoorArchetype02
                                                 :DoorArchetype03
                                                 :DoorArchetype04
                                                 :DoorArchetype05
                                                 :DoorArchetype06
                                                 :DoorArchetype07
                                                 :DoorArchetype08
                                                 :DoorArchetype09
                                                 :DoorArchetype10
                                                 :DoorArchetype11
                                                 :DoorArchetype12
                                                 :DoorArchetype13
                                                 :DoorArchetype14
                                                 :DoorArchetype15
                                               )
                                   ] ;
               rdfs:subClassOf :ElementArchetype .


###  https://w3id.org/at#ElementArchetype
:ElementArchetype rdf:type owl:Class .


###  https://w3id.org/at#Floor
:Floor rdf:type owl:Class ;
       rdfs:subClassOf :BuildingElement .


###  https://w3id.org/at#FloorArchetype
:FloorArchetype rdf:type owl:Class ;
                owl:equivalentClass [ rdf:type owl:Class ;
                                      owl:oneOf ( :FloorArchetype01
                                                  :FloorArchetype02
                                                  :FloorArchetype03
                                                  :FloorArchetype04
                                                  :FloorArchetype05
                                                  :FloorArchetype06
                                                  :FloorArchetype07
                                                  :FloorArchetype08
                                                  :FloorArchetype09
                                                  :FloorArchetype10
                                                  :FloorArchetype11
                                                  :FloorArchetype12
                                                  :FloorArchetype13
                                                  :FloorArchetype14
                                                  :FloorArchetype15
                                                )
                                    ] ;
                rdfs:subClassOf :ElementArchetype ;
                owl:disjointWith :WallArchetype .


###  https://w3id.org/at#FloorLayerSet
:FloorLayerSet rdf:type owl:Class ;
               owl:equivalentClass [ rdf:type owl:Class ;
                                     owl:oneOf ( :FloorLayerSet01
                                                 :FloorLayerSet02
                                                 :FloorLayerSet03
                                                 :FloorLayerSet04
                                                 :FloorLayerSet05
                                               )
                                   ] ;
               rdfs:subClassOf :ReferenceLayerSet .


###  https://w3id.org/at#GalleryHouse
:GalleryHouse rdf:type owl:Class ;
              rdfs:subClassOf :Residential .


###  https://w3id.org/at#Layer
:Layer rdf:type owl:Class .


###  https://w3id.org/at#LayerSet
:LayerSet rdf:type owl:Class .


###  https://w3id.org/at#MaisonetteHouse
:MaisonetteHouse rdf:type owl:Class ;
                 rdfs:subClassOf :Residential .


###  https://w3id.org/at#Material
:Material rdf:type owl:Class .


###  https://w3id.org/at#ReferenceLayerSet
:ReferenceLayerSet rdf:type owl:Class .


###  https://w3id.org/at#ReferenceMaterial
:ReferenceMaterial rdf:type owl:Class ;
                   owl:equivalentClass [ rdf:type owl:Class ;
                                         owl:oneOf ( :ReferenceMaterial01
                                                     :ReferenceMaterial02
                                                     :ReferenceMaterial03
                                                     :ReferenceMaterial04
                                                     :ReferenceMaterial05
                                                     :ReferenceMaterial06
                                                     :ReferenceMaterial07
                                                     :ReferenceMaterial08
                                                     :ReferenceMaterial09
                                                     :ReferenceMaterial10
                                                     :ReferenceMaterial11
                                                     :ReferenceMaterial12
                                                     :ReferenceMaterial13
                                                     :ReferenceMaterial14
                                                     :ReferenceMaterial15
                                                   )
                                       ] .


###  https://w3id.org/at#RenovationStatus
:RenovationStatus rdf:type owl:Class ;
                  owl:equivalentClass [ rdf:type owl:Class ;
                                        owl:oneOf ( :MajorRenovation
                                                    :MinorRenovation
                                                    :NoRenovation
                                                  )
                                      ] .


###  https://w3id.org/at#Residential
:Residential rdf:type owl:Class ;
             rdfs:subClassOf :BuildingType .


###  https://w3id.org/at#Roof
:Roof rdf:type owl:Class ;
      rdfs:subClassOf :BuildingElement .


###  https://w3id.org/at#RoofArchetype
:RoofArchetype rdf:type owl:Class ;
               owl:equivalentClass [ rdf:type owl:Class ;
                                     owl:oneOf ( :RoofArchetype01
                                                 :RoofArchetype02
                                                 :RoofArchetype03
                                                 :RoofArchetype04
                                                 :RoofArchetype05
                                                 :RoofArchetype06
                                                 :RoofArchetype07
                                                 :RoofArchetype08
                                                 :RoofArchetype09
                                                 :RoofArchetype10
                                                 :RoofArchetype11
                                                 :RoofArchetype12
                                                 :RoofArchetype13
                                                 :RoofArchetype14
                                                 :RoofArchetype15
                                               )
                                   ] ;
               rdfs:subClassOf :ElementArchetype .


###  https://w3id.org/at#RoofLayerSet
:RoofLayerSet rdf:type owl:Class ;
              owl:equivalentClass [ rdf:type owl:Class ;
                                    owl:oneOf ( :RoofLayerSet01
                                                :RoofLayerSet02
                                                :RoofLayerSet03
                                                :RoofLayerSet04
                                                :RoofLayerSet05
                                              )
                                  ] ;
              rdfs:subClassOf :ReferenceLayerSet .


###  https://w3id.org/at#SemiDetachedHouse
:SemiDetachedHouse rdf:type owl:Class ;
                   rdfs:subClassOf :Residential .


###  https://w3id.org/at#TerraceHouse
:TerraceHouse rdf:type owl:Class ;
              rdfs:subClassOf :Residential .


###  https://w3id.org/at#Wall
:Wall rdf:type owl:Class ;
      rdfs:subClassOf :BuildingElement .


###  https://w3id.org/at#WallArchetype
:WallArchetype rdf:type owl:Class ;
               owl:equivalentClass [ rdf:type owl:Class ;
                                     owl:oneOf ( :WallArchetype01
                                                 :WallArchetype02
                                                 :WallArchetype03
                                                 :WallArchetype04
                                                 :WallArchetype05
                                                 :WallArchetype06
                                                 :WallArchetype07
                                                 :WallArchetype08
                                                 :WallArchetype09
                                                 :WallArchetype10
                                                 :WallArchetype11
                                                 :WallArchetype12
                                                 :WallArchetype13
                                                 :WallArchetype14
                                                 :WallArchetype15
                                               )
                                   ] ;
               rdfs:subClassOf :ElementArchetype .


###  https://w3id.org/at#WallLayerSet
:WallLayerSet rdf:type owl:Class ;
              owl:equivalentClass [ rdf:type owl:Class ;
                                    owl:oneOf ( :WallLayerSet01
                                                :WallLayerSet02
                                                :WallLayerSet03
                                                :WallLayerSet04
                                                :WallLayerSet05
                                              )
                                  ] ;
              rdfs:subClassOf :ReferenceLayerSet .


###  https://w3id.org/at#Window
:Window rdf:type owl:Class ;
        rdfs:subClassOf :BuildingElement .


###  https://w3id.org/at#WindowArchetype
:WindowArchetype rdf:type owl:Class ;
                 owl:equivalentClass [ rdf:type owl:Class ;
                                       owl:oneOf ( :WindowArchetype01
                                                   :WindowArchetype02
                                                   :WindowArchetype03
                                                   :WindowArchetype04
                                                   :WindowArchetype05
                                                   :WindowArchetype06
                                                   :WindowArchetype07
                                                   :WindowArchetype08
                                                   :WindowArchetype09
                                                   :WindowArchetype10
                                                   :WindowArchetype11
                                                   :WindowArchetype12
                                                   :WindowArchetype13
                                                   :WindowArchetype14
                                                   :WindowArchetype15
                                                 )
                                     ] ;
                 rdfs:subClassOf :ElementArchetype .


