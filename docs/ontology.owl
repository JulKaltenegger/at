                    <rdf:Description rdf:about="https://w3id.org/at#ReferenceMaterial07"/>
                    <rdf:Description rdf:about="https://w3id.org/at#ReferenceMaterial08"/>
                    <rdf:Description rdf:about="https://w3id.org/at#ReferenceMaterial09"/>
                    <rdf:Description rdf:about="https://w3id.org/at#ReferenceMaterial10"/>
                    <rdf:Description rdf:about="https://w3id.org/at#ReferenceMaterial11"/>
