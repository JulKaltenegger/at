<?xml version="1.0"?>
<rdf:RDF xmlns="https://w3id.org/at#"
     xml:base="https://w3id.org/at"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:foaf="http://xmlns.com/foaf/0.1/"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:vann="http://purl.org/vocab/vann/"
     xmlns:terms="http://purl.org/dc/terms/">
    <owl:Ontology rdf:about="https://w3id.org/at#">
        <terms:contributor rdf:resource="https://w3id.org/at#André_Borrmann"/>
        <terms:contributor rdf:resource="https://w3id.org/at#Ekaterina_Petrova"/>
        <terms:contributor rdf:resource="https://w3id.org/at#Pieter_Pauwels"/>
        <terms:creator rdf:resource="https://orcid.org/0000-0002-9383-7234"/>
        <terms:description xml:lang="en">The Archetype Ontology for building engineering domain classifies buildings, building elements, layersets, and materials that can be assigned to existing building stock. As such, the classes offer to assign average values defined by typical building characteristics and serve as reasonable approximations when detailed building-specific data is unavailable.</terms:description>
        <terms:title xml:lang="en">Building Archetype Ontology</terms:title>
        <vann:preferredNamespacePrefix xml:lang="en">at</vann:preferredNamespacePrefix>
        <vann:preferredNamespaceUri xml:lang="en">https://w3id.org/at#</vann:preferredNamespaceUri>
        <rdfs:label></rdfs:label>
        <owl:versionInfo xml:lang="en">1.0</owl:versionInfo>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://purl.org/dc/terms/contributor -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/contributor"/>
    


    <!-- http://purl.org/dc/terms/creator -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/creator"/>
    


    <!-- http://purl.org/dc/terms/description -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/description"/>
    


    <!-- http://purl.org/dc/terms/title -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/title"/>
    


    <!-- http://purl.org/vocab/vann/preferredNamespacePrefix -->


    <owl:AnnotationProperty rdf:about="http://purl.org/vocab/vann/preferredNamespacePrefix"/>
    


    <!-- http://purl.org/vocab/vann/preferredNamespaceUri -->


    <owl:AnnotationProperty rdf:about="http://purl.org/vocab/vann/preferredNamespaceUri"/>
    


    <!-- http://xmlns.com/foaf/0.1/name -->


    <owl:AnnotationProperty rdf:about="http://xmlns.com/foaf/0.1/name"/>
    


    <!-- http://xmlns.com/foaf/0.1/weblog -->


    <owl:AnnotationProperty rdf:about="http://xmlns.com/foaf/0.1/weblog"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Datatypes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.w3.org/2001/XMLSchema#gYear -->


    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#gYear"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- https://w3id.org/at#constructionPeriod -->


    <owl:ObjectProperty rdf:about="https://w3id.org/at#constructionPeriod">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/at#Building"/>
        <rdfs:range rdf:resource="https://w3id.org/at#ConstructionPeriod"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/at#hasBuildingArchetype -->


    <owl:ObjectProperty rdf:about="https://w3id.org/at#hasBuildingArchetype">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/at#Building"/>
        <rdfs:range rdf:resource="https://w3id.org/at#BuildingArchetype"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/at#hasBuildingType -->


    <owl:ObjectProperty rdf:about="https://w3id.org/at#hasBuildingType">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/at#Building"/>
        <rdfs:range rdf:resource="https://w3id.org/at#BuildingType"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/at#hasElement -->


    <owl:ObjectProperty rdf:about="https://w3id.org/at#hasElement">
        <rdfs:domain rdf:resource="https://w3id.org/at#Building"/>
        <rdfs:range rdf:resource="https://w3id.org/at#BuildingElement"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/at#hasElementArchetype -->


    <owl:ObjectProperty rdf:about="https://w3id.org/at#hasElementArchetype">
        <rdfs:domain rdf:resource="https://w3id.org/at#BuildingElement"/>
        <rdfs:range rdf:resource="https://w3id.org/at#ElementArchetype"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/at#hasLayer -->


    <owl:ObjectProperty rdf:about="https://w3id.org/at#hasLayer">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/at#LayerSet"/>
        <rdfs:range rdf:resource="https://w3id.org/at#Layer"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/at#hasLayerSet -->


    <owl:ObjectProperty rdf:about="https://w3id.org/at#hasLayerSet">
        <rdfs:domain rdf:resource="https://w3id.org/at#BuildingElement"/>
        <rdfs:range rdf:resource="https://w3id.org/at#LayerSet"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/at#hasMaterial -->


    <owl:ObjectProperty rdf:about="https://w3id.org/at#hasMaterial">
        <rdfs:domain rdf:resource="https://w3id.org/at#Layer"/>
        <rdfs:range rdf:resource="https://w3id.org/at#Material"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/at#hasReferenceLayerSet -->


    <owl:ObjectProperty rdf:about="https://w3id.org/at#hasReferenceLayerSet">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/at#LayerSet"/>
        <rdfs:range rdf:resource="https://w3id.org/at#ReferenceLayerSet"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/at#hasReferenceMaterial -->


    <owl:ObjectProperty rdf:about="https://w3id.org/at#hasReferenceMaterial">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/at#Material"/>
        <rdfs:range rdf:resource="https://w3id.org/at#ReferenceMaterial"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/at#hasRenovationStatus -->


    <owl:ObjectProperty rdf:about="https://w3id.org/at#hasRenovationStatus">
        <rdfs:domain rdf:resource="https://w3id.org/at#Building"/>
        <rdfs:range rdf:resource="https://w3id.org/at#RenovationStatus"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/at#hasResidentialType -->


    <owl:ObjectProperty rdf:about="https://w3id.org/at#hasResidentialType">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/at#hasBuildingType"/>
        <rdfs:domain rdf:resource="https://w3id.org/at#Residential"/>
        <rdfs:range rdf:resource="https://w3id.org/at#ApartmentHouse"/>
        <rdfs:range rdf:resource="https://w3id.org/at#DetachedHouse"/>
        <rdfs:range rdf:resource="https://w3id.org/at#GalleryHouse"/>
        <rdfs:range rdf:resource="https://w3id.org/at#MaisonetteHouse"/>
        <rdfs:range rdf:resource="https://w3id.org/at#SemiDetachedHouse"/>
        <rdfs:range rdf:resource="https://w3id.org/at#TerraceHouse"/>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- https://w3id.org/at#isConstructedIn -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/at#isConstructedIn">
        <rdfs:domain rdf:resource="https://w3id.org/at#Building"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#gYear"/>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- https://w3id.org/at#ApartmentHouse -->


    <owl:Class rdf:about="https://w3id.org/at#ApartmentHouse">
        <rdfs:subClassOf rdf:resource="https://w3id.org/at#Residential"/>
    </owl:Class>
    


    <!-- https://w3id.org/at#Building -->


    <owl:Class rdf:about="https://w3id.org/at#Building"/>
    


    <!-- https://w3id.org/at#BuildingArchetype -->


    <owl:Class rdf:about="https://w3id.org/at#BuildingArchetype">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/at#BuildingArchetype01"/>
                    <rdf:Description rdf:about="https://w3id.org/at#BuildingArchetype02"/>
                    <rdf:Description rdf:about="https://w3id.org/at#BuildingArchetype03"/>
                    <rdf:Description rdf:about="https://w3id.org/at#BuildingArchetype04"/>
                    <rdf:Description rdf:about="https://w3id.org/at#BuildingArchetype05"/>
                    <rdf:Description rdf:about="https://w3id.org/at#BuildingArchetype06"/>
                    <rdf:Description rdf:about="https://w3id.org/at#BuildingArchetype07"/>
                    <rdf:Description rdf:about="https://w3id.org/at#BuildingArchetype08"/>
                    <rdf:Description rdf:about="https://w3id.org/at#BuildingArchetype09"/>
                    <rdf:Description rdf:about="https://w3id.org/at#BuildingArchetype10"/>
                    <rdf:Description rdf:about="https://w3id.org/at#BuildingArchetype11"/>
                    <rdf:Description rdf:about="https://w3id.org/at#BuildingArchetype12"/>
                    <rdf:Description rdf:about="https://w3id.org/at#BuildingArchetype13"/>
                    <rdf:Description rdf:about="https://w3id.org/at#BuildingArchetype14"/>
                    <rdf:Description rdf:about="https://w3id.org/at#BuildingArchetype15"/>
                    <rdf:Description rdf:about="https://w3id.org/at#BuildingArchetype16"/>
                    <rdf:Description rdf:about="https://w3id.org/at#BuildingArchetype17"/>
                    <rdf:Description rdf:about="https://w3id.org/at#BuildingArchetype18"/>
                    <rdf:Description rdf:about="https://w3id.org/at#BuildingArchetype19"/>
                    <rdf:Description rdf:about="https://w3id.org/at#BuildingArchetype20"/>
                    <rdf:Description rdf:about="https://w3id.org/at#BuildingArchetype21"/>
                    <rdf:Description rdf:about="https://w3id.org/at#BuildingArchetype22"/>
                    <rdf:Description rdf:about="https://w3id.org/at#BuildingArchetype23"/>
                    <rdf:Description rdf:about="https://w3id.org/at#BuildingArchetype24"/>
                    <rdf:Description rdf:about="https://w3id.org/at#BuildingArchetype25"/>
                    <rdf:Description rdf:about="https://w3id.org/at#BuildingArchetype26"/>
                    <rdf:Description rdf:about="https://w3id.org/at#BuildingArchetype27"/>
                    <rdf:Description rdf:about="https://w3id.org/at#BuildingArchetype28"/>
                    <rdf:Description rdf:about="https://w3id.org/at#BuildingArchetype29"/>
                    <rdf:Description rdf:about="https://w3id.org/at#BuildingArchetype30"/>
                    <rdf:Description rdf:about="https://w3id.org/at#BuildingArchetype31"/>
                    <rdf:Description rdf:about="https://w3id.org/at#BuildingArchetype32"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:comment>Building archetypes define and utilise core sets of representative construction structures and systems of a building type, formalised as exemplary buildings. BuildingArchetype os a ontrolled vocabulary (enumeration) containing named individuals (1..n)</rdfs:comment>
    </owl:Class>
    


    <!-- https://w3id.org/at#BuildingElement -->


    <owl:Class rdf:about="https://w3id.org/at#BuildingElement"/>
    


    <!-- https://w3id.org/at#BuildingType -->


    <owl:Class rdf:about="https://w3id.org/at#BuildingType">
        <rdfs:comment>A building type is a categorical classification of buildings based on the occupation type and other buiding-based characteristics.</rdfs:comment>
    </owl:Class>
    


    <!-- https://w3id.org/at#ConstructionPeriod -->


    <owl:Class rdf:about="https://w3id.org/at#ConstructionPeriod">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/at#1946"/>
                    <rdf:Description rdf:about="https://w3id.org/at#1964"/>
                    <rdf:Description rdf:about="https://w3id.org/at#1974"/>
                    <rdf:Description rdf:about="https://w3id.org/at#1991"/>
                    <rdf:Description rdf:about="https://w3id.org/at#2005"/>
                    <rdf:Description rdf:about="https://w3id.org/at#2014"/>
                    <rdf:Description rdf:about="https://w3id.org/at#2018"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
    </owl:Class>
    


    <!-- https://w3id.org/at#DetachedHouse -->


    <owl:Class rdf:about="https://w3id.org/at#DetachedHouse">
        <rdfs:subClassOf rdf:resource="https://w3id.org/at#Residential"/>
    </owl:Class>
    


    <!-- https://w3id.org/at#Door -->


    <owl:Class rdf:about="https://w3id.org/at#Door">
        <rdfs:subClassOf rdf:resource="https://w3id.org/at#BuildingElement"/>
    </owl:Class>
    


    <!-- https://w3id.org/at#DoorArchetype -->


    <owl:Class rdf:about="https://w3id.org/at#DoorArchetype">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/at#DoorArchetype01"/>
                    <rdf:Description rdf:about="https://w3id.org/at#DoorArchetype02"/>
                    <rdf:Description rdf:about="https://w3id.org/at#DoorArchetype03"/>
                    <rdf:Description rdf:about="https://w3id.org/at#DoorArchetype04"/>
                    <rdf:Description rdf:about="https://w3id.org/at#DoorArchetype05"/>
                    <rdf:Description rdf:about="https://w3id.org/at#DoorArchetype06"/>
                    <rdf:Description rdf:about="https://w3id.org/at#DoorArchetype07"/>
                    <rdf:Description rdf:about="https://w3id.org/at#DoorArchetype08"/>
                    <rdf:Description rdf:about="https://w3id.org/at#DoorArchetype09"/>
                    <rdf:Description rdf:about="https://w3id.org/at#DoorArchetype10"/>
                    <rdf:Description rdf:about="https://w3id.org/at#DoorArchetype11"/>
                    <rdf:Description rdf:about="https://w3id.org/at#DoorArchetype12"/>
                    <rdf:Description rdf:about="https://w3id.org/at#DoorArchetype13"/>
                    <rdf:Description rdf:about="https://w3id.org/at#DoorArchetype14"/>
                    <rdf:Description rdf:about="https://w3id.org/at#DoorArchetype15"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/at#ElementArchetype"/>
    </owl:Class>
    


    <!-- https://w3id.org/at#ElementArchetype -->


    <owl:Class rdf:about="https://w3id.org/at#ElementArchetype"/>
    


    <!-- https://w3id.org/at#Floor -->


    <owl:Class rdf:about="https://w3id.org/at#Floor">
        <rdfs:subClassOf rdf:resource="https://w3id.org/at#BuildingElement"/>
    </owl:Class>
    


    <!-- https://w3id.org/at#FloorArchetype -->


    <owl:Class rdf:about="https://w3id.org/at#FloorArchetype">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/at#FloorArchetype01"/>
                    <rdf:Description rdf:about="https://w3id.org/at#FloorArchetype02"/>
                    <rdf:Description rdf:about="https://w3id.org/at#FloorArchetype03"/>
                    <rdf:Description rdf:about="https://w3id.org/at#FloorArchetype04"/>
                    <rdf:Description rdf:about="https://w3id.org/at#FloorArchetype05"/>
                    <rdf:Description rdf:about="https://w3id.org/at#FloorArchetype06"/>
                    <rdf:Description rdf:about="https://w3id.org/at#FloorArchetype07"/>
                    <rdf:Description rdf:about="https://w3id.org/at#FloorArchetype08"/>
                    <rdf:Description rdf:about="https://w3id.org/at#FloorArchetype09"/>
                    <rdf:Description rdf:about="https://w3id.org/at#FloorArchetype10"/>
                    <rdf:Description rdf:about="https://w3id.org/at#FloorArchetype11"/>
                    <rdf:Description rdf:about="https://w3id.org/at#FloorArchetype12"/>
                    <rdf:Description rdf:about="https://w3id.org/at#FloorArchetype13"/>
                    <rdf:Description rdf:about="https://w3id.org/at#FloorArchetype14"/>
                    <rdf:Description rdf:about="https://w3id.org/at#FloorArchetype15"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/at#ElementArchetype"/>
        <owl:disjointWith rdf:resource="https://w3id.org/at#WallArchetype"/>
    </owl:Class>
    


    <!-- https://w3id.org/at#FloorLayerSet -->


    <owl:Class rdf:about="https://w3id.org/at#FloorLayerSet">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/at#FloorLayerSet01"/>
                    <rdf:Description rdf:about="https://w3id.org/at#FloorLayerSet02"/>
                    <rdf:Description rdf:about="https://w3id.org/at#FloorLayerSet03"/>
                    <rdf:Description rdf:about="https://w3id.org/at#FloorLayerSet04"/>
                    <rdf:Description rdf:about="https://w3id.org/at#FloorLayerSet05"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/at#ReferenceLayerSet"/>
    </owl:Class>
    


    <!-- https://w3id.org/at#GalleryHouse -->


    <owl:Class rdf:about="https://w3id.org/at#GalleryHouse">
        <rdfs:subClassOf rdf:resource="https://w3id.org/at#Residential"/>
    </owl:Class>
    


    <!-- https://w3id.org/at#Layer -->


    <owl:Class rdf:about="https://w3id.org/at#Layer"/>
    


    <!-- https://w3id.org/at#LayerSet -->


    <owl:Class rdf:about="https://w3id.org/at#LayerSet"/>
    


    <!-- https://w3id.org/at#MaisonetteHouse -->


    <owl:Class rdf:about="https://w3id.org/at#MaisonetteHouse">
        <rdfs:subClassOf rdf:resource="https://w3id.org/at#Residential"/>
    </owl:Class>
    


    <!-- https://w3id.org/at#Material -->


    <owl:Class rdf:about="https://w3id.org/at#Material"/>
    


    <!-- https://w3id.org/at#ReferenceLayerSet -->


    <owl:Class rdf:about="https://w3id.org/at#ReferenceLayerSet"/>
    


    <!-- https://w3id.org/at#ReferenceMaterial -->


    <owl:Class rdf:about="https://w3id.org/at#ReferenceMaterial">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/at#ReferenceMaterial01"/>
                    <rdf:Description rdf:about="https://w3id.org/at#ReferenceMaterial02"/>
                    <rdf:Description rdf:about="https://w3id.org/at#ReferenceMaterial03"/>
                    <rdf:Description rdf:about="https://w3id.org/at#ReferenceMaterial04"/>
                    <rdf:Description rdf:about="https://w3id.org/at#ReferenceMaterial05"/>
