                    <rdf:Description rdf:about="https://w3id.org/at#ReferenceMaterial15"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
    </owl:Class>
    


    <!-- https://w3id.org/at#RenovationStatus -->


    <owl:Class rdf:about="https://w3id.org/at#RenovationStatus">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/at#MajorRenovation"/>
                    <rdf:Description rdf:about="https://w3id.org/at#MinorRenovation"/>
                    <rdf:Description rdf:about="https://w3id.org/at#NoRenovation"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
    </owl:Class>
    


    <!-- https://w3id.org/at#Residential -->


    <owl:Class rdf:about="https://w3id.org/at#Residential">
        <rdfs:subClassOf rdf:resource="https://w3id.org/at#BuildingType"/>
    </owl:Class>
    


    <!-- https://w3id.org/at#Roof -->


    <owl:Class rdf:about="https://w3id.org/at#Roof">
        <rdfs:subClassOf rdf:resource="https://w3id.org/at#BuildingElement"/>
    </owl:Class>
    


    <!-- https://w3id.org/at#RoofArchetype -->


    <owl:Class rdf:about="https://w3id.org/at#RoofArchetype">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
