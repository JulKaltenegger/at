  "http://purl.org/dc/terms/description" : [ {
    "@language" : "en",
    "@value" : "The Archetype Ontology for building engineering domain classifies buildings, building elements, layersets, and materials that can be assigned to existing building stock. As such, the classes offer to assign average values defined by typical building characteristics and serve as reasonable approximations when detailed building-specific data is unavailable."
  } ],
